{
  "name": "card-game-28",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "electron .",
    "electron:build": "npm run build && electron-builder --mac dmg"
  },
  "dependencies": {
    "framer-motion": "^11.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "vite": "^8.0.10"
  },
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.fawwaaz.game28",
    "productName": "28 — The Card Game",
    "icon": "icon.icns",
    "mac": {
      "category": "public.app-category.games",
      "icon": "icon.icns",
      "target": [
        "dmg"
      ]
    },
    "dmg": {
      "title": "28 — The Card Game",
      "icon": "icon.icns",
      "contents": [
        {
          "x": 150,
          "y": 185,
          "type": "file"
        },
        {
          "x": 390,
          "y": 185,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "icon.icns"
    ]
  }
}